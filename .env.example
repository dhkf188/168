# ========== 数据库配置 ==========
# 主数据库（Aiven PostgreSQL）
DATABASE_URL=postgresql://admin:Admin@123456@localhost:5432/employeemonitor?sslmode=require

# 备用数据库（可选）
BACKUP_DATABASE_URL=postgresql://backup_user:Backup@123456@localhost:5433/employeemonitor_backup?sslmode=require
USE_BACKUP_DB=false

# Aiven SSL证书
CA_CERT_PATH=./ca.pem

# ========== 管理员账号 ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456

# ========== JWT配置 ==========
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== 存储配置 ==========
SCREENSHOT_DIR=/data/screenshots
SCREENSHOT_FORMAT=webp
SCREENSHOT_QUALITY=80
SCREENSHOT_INTERVAL=60

# ========== 自动清理配置 ==========
AUTO_CLEANUP_ENABLED=true
CLEANUP_INTERVAL=21600
SCREENSHOT_RETENTION_HOURS=4

# ========== Redis配置 ==========
REDIS_URL=redis://localhost:6379/0

# ========== 性能配置 ==========
DEBUG=false
GUNICORN_WORKERS=2
LOG_LEVEL=info