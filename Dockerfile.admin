# 构建阶段
FROM node:18-alpine as builder

WORKDIR /app

# 复制依赖文件
COPY admin_package.json package.json
COPY admin_vite.config.js vite.config.js
COPY admin_index.html index.html
COPY admin_*.js ./
COPY admin_*.vue ./

# 安装依赖并构建
RUN npm install && npm run build

# 运行阶段
FROM nginx:alpine

# 复制构建产物
COPY --from=builder /app/dist /usr/share/nginx/html

# 复制nginx配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]